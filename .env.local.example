# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Square
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key
NEXT_PUBLIC_SQUARE_APP_ID=your-square-app-id
NEXT_PUBLIC_SQUARE_LOCATION_ID=your-square-location-id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notification emails (cron calls /api/notifications/send-emails every 5 min)
# Set a secret and use it in Vercel Cron or external scheduler: Authorization: Bearer <secret>
NOTIFICATION_CRON_SECRET=

# Gmail SMTP (for sending invite emails)
# Use your Google Workspace email + App Password (not regular password)
# Create App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_USER=info@MikeTintnerProductions.com
SMTP_APP_PASSWORD=your-16-char-app-password

# Google Calendar API (for automated scheduling)
# 1. Create project at console.cloud.google.com, enable Calendar API
# 2. Create Service Account, download JSON
# 3. Share your Google Calendar with the service account email (Make changes to events)
# 4. Add these from the JSON:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Your calendar email (e.g. info@miketintnerproductions.com) or calendar ID from Google Calendar settings
GOOGLE_CALENDAR_ID=info@miketintnerproductions.com
